{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "getaway.flight",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "flightNumber", "origin", "destination", "departsAt", "arrivesAt", "cabin", "durationMinutes"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": { "const": "getaway.flight" },
    "flightNumber": { "type": "string", "pattern": "^[A-Z0-9]{2}[0-9]{1,4}$" },
    "origin": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "destination": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "departsAt": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}(:[0-9]{2})?(Z|[+-][0-9]{2}:[0-9]{2})?$" },
    "arrivesAt": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}(:[0-9]{2})?(Z|[+-][0-9]{2}:[0-9]{2})?$" },
    "cabin": { "$ref": "#/$defs/cabin" },
    "durationMinutes": { "type": "integer", "minimum": 1 },
    "aircraft": { "type": "string", "minLength": 1 },
    "aircraftCode": { "type": "string", "pattern": "^[A-Z0-9]{3,4}$" },
    "seatQuality": { "$ref": "#/$defs/seatQuality" },
    "price": { "$ref": "#/$defs/money" }
  },
  "$defs": {
    "money": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount", "currency"],
      "properties": {
        "amount": { "type": "integer", "minimum": 0 },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      }
    },
    "seatQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict"],
      "properties": {
        "verdict": { "enum": ["suite", "solid", "dated", "barely", "verify"] },
        "product": { "type": ["string", "null"] },
        "note": { "type": ["string", "null"] }
      }
    },
    "cabin": { "enum": ["economy", "premium", "business", "first"] }
  }
}
