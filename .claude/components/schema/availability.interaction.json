{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "getaway.availability interaction",
  "type": "object",
  "additionalProperties": false,
  "required": ["date", "cabin"],
  "properties": {
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "cabin": { "enum": ["economy", "premium", "business", "first"] }
  }
}
