{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "getaway.option-picker",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "label", "options"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": { "const": "getaway.option-picker" },
    "label": { "type": "string", "minLength": 1 },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["optionId", "origin", "destination", "date", "program", "miles", "taxes"],
        "properties": {
          "optionId": { "type": "string", "minLength": 1 },
          "origin": { "type": "string", "pattern": "^[A-Z]{3}$" },
          "destination": { "type": "string", "pattern": "^[A-Z]{3}$" },
          "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "program": { "type": "string", "minLength": 1 },
          "miles": { "type": "integer", "minimum": 1 },
          "taxes": { "$ref": "#/$defs/money" },
          "cabin": { "$ref": "#/$defs/cabin" }
        }
      }
    }
  },
  "$defs": {
    "money": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount", "currency"],
      "properties": {
        "amount": { "type": "integer", "minimum": 0 },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      }
    },
    "cabin": { "enum": ["economy", "premium", "business", "first"] }
  }
}
